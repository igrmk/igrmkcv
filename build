#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"
mkdir -p output

export TEXINPUTS=./examples:./output:
export TEXMFHOME=.venv

build_file() {
	max_print_line=200 xelatex -output-driver="xdvipdfmx -z 0" -output-directory output "examples/$1.tex"
	pdftoppm -singlefile -png -r 300 "output/$1.pdf" "output/$1"
}

build_file igrmk-full

if [[ "${1:-}" == "all" ]]; then
	build_file igrmk-net
	build_file igrmk-hft
	build_file igrmk-python
fi

