#!/usr/bin/env bash
set -euo pipefail

if [[ "$#" -lt 1 ]]; then
    echo "Usage: $0 <scope: main|all> [prefix]"
    exit 1
fi

scope="$1"
prefix="${2:-}"

if [[ "$scope" != "main" && "$scope" != "all" ]]; then
	echo "Error: scope must be either 'main' or 'all'"
	exit 1
fi

cd "$(dirname "$0")"
mkdir -p output

build_file() {
	tectonic -Z search-path=. -o output "examples/$1.tex"

	if [[ -n "$prefix" ]]; then
		mv "output/$1.pdf" "output/$prefix-$1.pdf"
	fi

	pdftoppm -singlefile -png -r 300 "output/${prefix:+$prefix-}$1.pdf" "output/${prefix:+$prefix-}$1"
}

build_file igrmk-full

if [[ "${1:-}" == "all" ]]; then
	build_file igrmk-net
	build_file igrmk-hft
	build_file igrmk-python
fi

